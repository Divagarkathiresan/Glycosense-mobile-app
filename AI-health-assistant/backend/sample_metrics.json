  "curl_examples": [
    {
      "description": "Login first to get token",
      "command": "curl -X POST http://192.168.0.6:8080/login -H 'Content-Type: application/json' -d '{\"email\":\"your@email.com\",\"password\":\"yourpassword\"}'"
    },
    {
      "description": "Submit risk assessment (replace YOUR_TOKEN with actual token)",
      "command": "curl -X POST http://192.168.0.6:8080/diabetes-risk -H 'Content-Type: application/json' -H 'Authorization: Bearer YOUR_TOKEN' -d '{\"glucose_value\":95,\"measurement_context\":\"fasting\",\"trend\":\"stable\",\"symptoms\":\"none\",\"medication_type\":\"none\",\"meal_type\":\"none\",\"diabetes_status\":\"no_diabetes\",\"age\":35,\"weight_kg\":70,\"height_cm\":170,\"family_history\":false,\"physical_activity\":\"moderate\"}'"
    },
    {
      "description": "Get all metrics",
      "command": "curl -X GET http://192.168.0.6:8080/user-metrics -H 'Authorization: Bearer YOUR_TOKEN'"
    },
    {
      "description": "Get latest risk",
      "command": "curl -X GET http://192.168.0.6:8080/diabetes-risk/latest -H 'Authorization: Bearer YOUR_TOKEN'"
    }
  ]
